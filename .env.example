# Twilio credentials
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
FROM_PHONE=your_twilio_number

# Pretty Good AI test number (do not change)
TO_PHONE=+18054398008

# OpenAI API key
OPENAI_API_KEY=your_openai_api_key

# Public URL for Twilio webhooks (your ngrok or deployed URL, without trailing slash)
# Example: PUBLIC_URL=1234-56-78-90.ngrok-free.app
PUBLIC_URL=your_public_url
